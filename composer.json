{
    "name": "coyote/framework",
    "description": "PHP Micro Framework Leve e Completo",
    "type": "library",
    "license": "MIT",
    "keywords": ["framework", "php", "micro", "coyote"],
    "homepage": "https://github.com/coyoteframework/framework",
    "authors": [
        {
            "name": "Coyote Framework Team",
            "email": "dev@coyoteframework.org"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Coyote\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Coyote\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Coyote\\Autoloader::register"
        ],
        "optimize": [
            "@php src/Cli/Commands/OptimizeCommand.php"
        ],
        "cache:clear": [
            "@php src/Cli/Commands/CacheClearCommand.php"
        ],
        "test": [
            "@php vendor/bin/phpunit"
        ],
        "test-coverage": [
            "@php vendor/bin/phpunit --coverage-html coverage"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "scripts-descriptions": {
        "optimize": "Otimizar framework para produção",
        "cache:clear": "Limpar cache do framework",
        "test": "Executar testes unitários",
        "test-coverage": "Executar testes com cobertura de código",
        "analyse": "Executar análise estática com PHPStan",
        "check": "Executar todos os checks (testes + análise)"
    },
    "config": {
        "sort-packages": true,
        "platform-check": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "coyote": {
            "version": "1.0.0-dev",
            "providers": [
                "Coyote\\Providers\\ConfigServiceProvider",
                "Coyote\\Providers\\EventServiceProvider",
                "Coyote\\Providers\\LogServiceProvider"
            ],
            "aliases": {
                "App": "Coyote\\Support\\Facades\\App",
                "Config": "Coyote\\Support\\Facades\\Config",
                "Log": "Coyote\\Support\\Facades\\Log"
            }
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "support": {
        "issues": "https://github.com/coyoteframework/framework/issues",
        "source": "https://github.com/coyoteframework/framework",
        "docs": "https://coyoteframework.org/docs"
    }
}