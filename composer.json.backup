{
    "name": "coyote/framework",
    "description": "PHP Micro Framework Leve e Completo",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Coyote Framework Team",
            "email": "dev@coyoteframework.org"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Coyote\\": "vendors/coyote/",
            "App\\": "app/"
        },
        "files": [
            "vendors/autoload.php",
            "vendors/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Coyote\\Autoloader::register"
        ],
        "optimize": [
            "@php vendors/coyote/Cli/Commands/OptimizeCommand.php"
        ],
        "cache:clear": [
            "@php vendors/coyote/Cli/Commands/CacheClearCommand.php"
        ],
        "test": [
            "@php vendor/bin/phpunit"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ]
    },
    "scripts-descriptions": {
        "optimize": "Otimizar framework para produção",
        "cache:clear": "Limpar cache do framework",
        "test": "Executar testes",
        "analyse": "Executar análise estática com PHPStan"
    },
    "config": {
        "sort-packages": true,
        "platform-check": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "coyote": {
            "version": "1.0.0-dev",
            "providers": [
                "Coyote\\Providers\\ConfigServiceProvider",
                "Coyote\\Providers\\EventServiceProvider",
                "Coyote\\Providers\\LogServiceProvider"
            ],
            "aliases": {
                "App": "Coyote\\Support\\Facades\\App",
                "Config": "Coyote\\Support\\Facades\\Config",
                "Log": "Coyote\\Support\\Facades\\Log"
            }
        }
    }
}